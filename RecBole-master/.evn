  ### RecBole local environment configuration
  # Keep this file local; docker-compose sẽ đọc các biến bên dưới.

  # Để trống trong giai đoạn test (API mở). Khi muốn bảo vệ, đặt key và restart docker.
  API_KEY=

  # Danh sách origin được phép truy cập từ browser, cách nhau dấu phẩy.
  # Ví dụ: ALLOWED_ORIGINS=http://localhost:3000,http://192.168.2.70:3000
  ALLOWED_ORIGINS=*

  # Lịch retrain (mặc định: 02:00 mỗi ngày, kiểm tra lại mỗi giờ).
  RETRAIN_HOUR=2
  RETRAIN_MINUTE=0
  RETRAIN_CHECK_INTERVAL=3600
  